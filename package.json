{
  "name": "termpal",
  "version": "1.0.1",
  "description": "Shape your terminal theme in real time",
  "keywords": [
    "ansi",
    "color",
    "osc",
    "palette",
    "terminal",
    "theme"
  ],
  "license": "MIT",
  "repository": "clctv/termpal",
  "bin": {
    "termpal": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "release": "pnpm run build && release-it --only-version",
    "prepare": "husky"
  },
  "dependencies": {
    "@inquirer/select": "^5.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@release-it/conventional-changelog": "^10.0.6",
    "@rslib/core": "^0.20.0",
    "@types/node": "^24.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "release-it": "^19.2.4",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
